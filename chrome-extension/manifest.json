{
  "manifest_version": 3,
  "name": "WB AutoFund",
  "version": "2.9.0",
  "description": "Автопополнение и безопасное управление рекламными кампаниями Wildberries.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["http://5.35.82.229/*"],
  "background": {"service_worker": "background.js"},
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [{
    "matches": ["https://cmp.wildberries.ru/*"],
    "js": ["content.js"],
    "css": ["content.css", "search.css"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_title": "WB AutoFund",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  }
}
