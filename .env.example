PORT=4173
HOST=0.0.0.0
NODE_ENV=production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=replace_with_64_hex_characters
# Login for the web panel. Use a unique password of at least 12 characters.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_long_random_password
# Safety switch. Keep false until demo checks and WB permissions are verified.
WB_LIVE_DEPOSITS=false
# Separate safety switch for automatic launch of paused/ready campaigns.
WB_LIVE_RESUME=false
WB_LIVE_PAUSE=false
WB_API_BASE=https://advert-api.wildberries.ru
